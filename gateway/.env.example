# Servidor HTTP/WS do notebook. Não contém TLS; um proxy/túnel futuro pode ficar à frente.
APP_PORT=8080
APP_HOST=0.0.0.0

# simulation ou factory
MODE=simulation
FACTORY_COMMANDS_ENABLED=true
FACTORY_INFER_WAITING_ON_BOOT=false
FACTORY_BOOTSTRAP_GRACE_MS=6000

# Simulação local:
MQTT_URL=mqtt://127.0.0.1:1883
# Na fábrica, confirmar em campo e trocar por algo como:
# MQTT_URL=mqtt://192.168.0.10:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID_PREFIX=eldorado-factory-gateway
MQTT_PROTOCOL_VERSION=4
MQTT_KEEPALIVE_SECONDS=30
MQTT_RECONNECT_PERIOD_MS=2000

MQTT_ORDER_TOPIC=f/o/order
MQTT_ORDER_STATE_TOPIC=f/i/order
MQTT_STOCK_TOPIC=f/i/stock
MQTT_STATION_STATE_TOPIC=f/i/state/+

MQTT_ENABLE_ENVIRONMENT_TOPICS=true
MQTT_ENABLE_CAMERA_TOPIC=false
MQTT_ENABLE_RAW_DIAGNOSTICS=true

# Modo temporário de descoberta. Exemplo: i/#,f/i/#
# Uma assinatura ampla i/# também recebe i/cam, mesmo se a opção específica estiver false.
MQTT_EXTRA_SUBSCRIPTIONS=
TOPIC_HISTORY_LIMIT=100

ORDER_ACCEPTANCE_TIMEOUT_MS=10000
# Padrão correto: UTC real. Use 725 somente se o relógio da fábrica for confirmado como incompatível.
ORDER_TIMESTAMP_OFFSET_MINUTES=0
STOCK_STALE_AFTER_MS=30000
TOPIC_STALE_AFTER_MS=30000

SIMULATION_SCENARIO=normal
SIMULATION_SPEED=1
SIMULATION_SNAPSHOT_PERIOD_MS=2000
SIMULATION_EMIT_SHIPPED=false
